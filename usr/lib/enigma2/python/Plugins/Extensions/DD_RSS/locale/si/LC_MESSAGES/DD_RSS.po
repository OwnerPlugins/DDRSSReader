msgid "Add"
msgstr "එකතු කරන්න"

msgid "Close"
msgstr "වසන්න"

msgid "Congrats! You already have the latest version..."
msgstr "Congratulazioni! Hai già l'ultima versione..."

msgid "Delete"
msgstr "මකන්න"

msgid "Do you want to install update ( %s ) now?"
msgstr "Vuoi installare l'aggiornamento ( %s ) ora?"

msgid "Download failed: {}"
msgstr "බාගැනීම අසාර්ථක විය: {}"

msgid "Download timeout (10s)"
msgstr "බාගැනීමේ කල් ඉකුත්වීම (තත්පර 10)"

msgid "Edit"
msgstr "සංස්කරණය කරන්න"

msgid "Empty response from server"
msgstr "සේවාදායකයෙන් හිස් ප්‍රතිචාරය"

msgid "Error: {}"
msgstr "දෝෂය: {}"

msgid "Failed to parse RSS feed"
msgstr "RSS සංග්‍රහය විග්‍රහ කිරීමට අසමත් විය"

msgid "Failed to parse XML file"
msgstr "XML ගොනුව විග්‍රහ කිරීමට අසමත් විය"

msgid "Feeds imported successfully"
msgstr "සංග්‍රහ සාර්ථකව ආනයනය කරන ලදී"

msgid "Import"
msgstr "ආනයනය කරන්න"

msgid "Keyboard"
msgstr "යතුරු පුවරුව"

msgid "No XML file found at /tmp/feeds.xml"
msgstr "/tmp/feeds.xml හි XML ගොනුවක් හමු නොවීය"

msgid "Save"
msgstr "Salva"

msgid "Select"
msgstr "Seleziona"

msgid "Setup RSS FEED v.%s"
msgstr "RSS FEED v.%s සකසන්න"

msgid "Update"
msgstr "Aggiorna"

msgid "Update Aborted!"
msgstr "Aggiornamento annullato!"

msgid "Update check failed!"
msgstr "යාවත්කාලීන පරීක්ෂාව අසාර්ථක විය!"
