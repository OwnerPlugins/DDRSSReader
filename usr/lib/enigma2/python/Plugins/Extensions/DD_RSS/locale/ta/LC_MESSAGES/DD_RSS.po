msgstr "/tmp/feeds.xml இல் XML கோப்பு இல்லை"

msgid "Save"
msgstr "Salva"

msgid "Select"
msgstr "Seleziona"

msgid "Setup RSS FEED v.%s"
msgstr "RSS ஊட்டத்தை அமைக்கவும் v.%s"

msgid "Update"
msgstr "Aggiorna"

msgid "Update Aborted!"
msgstr "Aggiornamento annullato!"

msgid "Update check failed!"
msgstr "புதுப்பிப்பு சரிபார்ப்பு தோல்வியடைந்தது!"
